<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SeafarerMS – <%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<aside class="sidebar">
  <div class="sidebar-brand">
    <a href="/" class="logo">
      <div class="logo-icon">⚓</div>
      <div><h1>SeafarerMS</h1><p>Management System</p></div>
    </a>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section-title">Main</div>
    <a href="/" class="nav-item <%= page==='dashboard'?'active':'' %>"><span class="icon"><i class="fa-solid fa-gauge"></i></span> Dashboard</a>
    <div class="nav-section-title">Management</div>
    <a href="/seafarers" class="nav-item <%= page==='seafarers'?'active':'' %>"><span class="icon"><i class="fa-solid fa-user-tie"></i></span> Seafarers</a>
    <a href="/vessels"   class="nav-item <%= page==='vessels'?'active':'' %>"><span class="icon"><i class="fa-solid fa-ship"></i></span> Vessels</a>
    <a href="/contracts" class="nav-item <%= page==='contracts'?'active':'' %>"><span class="icon"><i class="fa-solid fa-file-contract"></i></span> Contracts</a>
    <a href="/certs"     class="nav-item <%= page==='certs'?'active':'' %>"><span class="icon"><i class="fa-solid fa-certificate"></i></span> Certifications</a>
    <div class="nav-section-title">Analytics</div>
    <a href="/reports"   class="nav-item <%= page==='reports'?'active':'' %>"><span class="icon"><i class="fa-solid fa-chart-bar"></i></span> Reports</a>
  </nav>
  <div class="sidebar-footer">
    <a href="/logout" style="display:flex;align-items:center;gap:8px;color:rgba(255,255,255,0.6);text-decoration:none;font-size:13px;padding:8px 0;">
      <i class="fa-solid fa-right-from-bracket"></i> Logout
    </a>
    <p>© 2024 SeafarerMS v1.0</p>
  </div>
</aside>
<main class="main">
  <div class="topbar">
    <div class="topbar-title">
      <h2><%= title %></h2>
      <p><%= subtitle %></p>
    </div>
    <div class="topbar-right">
      <span class="topbar-badge">⚓ Maritime System</span>
    </div>
  </div>
  <div class="content">
