<%- include('partials/header', { title: 'Dashboard', subtitle: 'Welcome to Seafarer Management System', page: 'dashboard' }) %>

<div class="page-hero">
  <h2>🌊 Seafarer Management System</h2>
  <p>Manage vessels, crew, contracts and certifications from one place</p>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon blue">👨‍✈️</div>
    <div class="stat-info">
      <h3><%= totalSeafarers[0].cnt %></h3>
      <p>Total Seafarers</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon teal">🚢</div>
    <div class="stat-info">
      <h3><%= totalVessels[0].cnt %></h3>
      <p>Total Vessels</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">📋</div>
    <div class="stat-info">
      <h3><%= activeContracts[0].cnt %></h3>
      <p>Active Contracts</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon rose">📊</div>
    <div class="stat-info">
      <h3><%= recentLogs.length %></h3>
      <p>Recent Activities</p>
    </div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">

  <div class="card">
    <div class="card-header">
      <h3><i class="fa-solid fa-clock-rotate-left" style="color:var(--accent)"></i> Recent Activity Log</h3>
    </div>
    <div class="card-body">
      <% if(recentLogs.length === 0) { %>
        <p style="color:var(--muted);text-align:center;padding:20px">No activity yet</p>
      <% } else { %>
        <% recentLogs.forEach(log => { %>
          <div class="audit-item">
            <div class="audit-dot <%= log.action_type %>"></div>
            <div class="audit-text">
              <p><strong><%= log.action_type %></strong> on <em><%= log.table_name %></em> — <%= log.description %></p>
              <span><%= new Date(log.action_time).toLocaleString() %></span>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3><i class="fa-solid fa-compass" style="color:var(--accent)"></i> Quick Navigation</h3>
    </div>
    <div class="card-body" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <a href="/seafarers" class="btn btn-primary" style="justify-content:center;padding:16px">👨‍✈️ Seafarers</a>
      <a href="/vessels"   class="btn btn-success" style="justify-content:center;padding:16px">🚢 Vessels</a>
      <a href="/contracts" class="btn btn-warning" style="justify-content:center;padding:16px">📋 Contracts</a>
      <a href="/certs"     class="btn btn-outline" style="justify-content:center;padding:16px">🏅 Certifications</a>
      <a href="/reports"   class="btn btn-danger"  style="justify-content:center;padding:16px;grid-column:span 2">📊 View Reports</a>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
