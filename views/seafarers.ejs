<%- include('partials/header', { title: 'Seafarers', subtitle: 'Manage all seafarer records', page: 'seafarers' }) %>

<% if(msg) { %>
<div class="toast <%= msg==='error'?'toast-error':'toast-success' %>">
  <%= msg==='added'?'✅ Seafarer added successfully!':msg==='updated'?'✅ Seafarer updated successfully!':msg==='deleted'?'🗑️ Seafarer deleted!':'❌ Error: '+detail %>
</div>
<% } %>
<div class="page-hero">
  <h2>👨✈️ Seafarers Registry</h2>
  <p>View, add, update and remove seafarer records</p>
</div>

<div class="card">
  <div class="card-header">
    <h3><i class="fa-solid fa-plus" style="color:var(--accent)"></i> Add New Seafarer</h3>
  </div>
  <div class="card-body">
    <form action="/seafarers/add" method="POST">
      <div class="form-grid">
        <div class="form-group"><label>Full Name</label><input name="full_name" required placeholder="e.g. John Smith"></div>
        <div class="form-group"><label>Date of Birth</label><input type="date" name="date_of_birth" required></div>
        <div class="form-group"><label>Nationality</label><input name="nationality" required placeholder="e.g. Filipino"></div>
        <div class="form-group"><label>Passport No</label><input name="passport_no" required placeholder="e.g. PH123456"></div>
        <div class="form-group"><label>Email</label><input type="email" name="email" placeholder="email@example.com"></div>
        <div class="form-group"><label>Phone (10 digits)</label><input name="phone" placeholder="9121234567" pattern="[0-9]{10}" maxlength="10" title="Enter exactly 10 digits"></div>
        <div class="form-group">
          <label>Rank</label>
          <select name="rank_id">
            <option value="">-- Select Rank --</option>
            <% ranks.forEach(r => { %><option value="<%= r.rank_id %>"><%= r.rank_name %> (<%= r.department %>)</option><% }) %>
          </select>
        </div>
      </div>
      <div class="form-actions" style="margin-top:16px">
        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add Seafarer</button>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3><i class="fa-solid fa-list" style="color:var(--accent)"></i> All Seafarers (<%= seafarers.length %>)</h3>
    <div class="search-bar" style="margin:0">
      <input type="text" id="searchInput" placeholder="🔍 Search seafarers..." onkeyup="filterTable('searchInput','seafarerTable')">
    </div>
  </div>
  <div class="card-body" style="padding:0">
    <div class="table-wrap">
      <table id="seafarerTable">
        <thead>
          <tr>
            <th>#</th><th>Name</th><th>Nationality</th><th>Passport</th>
            <th>Rank</th><th>Department</th><th>Email</th><th>Status</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% seafarers.forEach(s => { %>
          <tr>
            <td><strong><%= s.seafarer_id %></strong></td>
            <td><strong><%= s.full_name %></strong></td>
            <td><%= s.nationality %></td>
            <td><code style="background:#f1f5f9;padding:2px 6px;border-radius:4px;font-size:12px"><%= s.passport_no %></code></td>
            <td><%= s.rank_name || '—' %></td>
            <td><%= s.department || '—' %></td>
            <td style="font-size:12px"><%= s.email || '—' %></td>
            <td>
              <% if(s.status==='Active') { %><span class="badge badge-success">Active</span>
              <% } else if(s.status==='On Leave') { %><span class="badge badge-warning">On Leave</span>
              <% } else { %><span class="badge badge-muted">Retired</span><% } %>
            </td>
            <td>
              <button class="btn btn-warning btn-sm" onclick="openEdit(<%= JSON.stringify(s) %>)"><i class="fa-solid fa-pen"></i></button>
              <form action="/seafarers/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this seafarer?')">
                <input type="hidden" name="seafarer_id" value="<%= s.seafarer_id %>">
                <button type="submit" class="btn btn-danger btn-sm"><i class="fa-solid fa-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="editModal">
  <div class="modal">
    <div class="modal-header">
      <h3>✏️ Edit Seafarer</h3>
      <button class="modal-close" onclick="closeModal('editModal')">✕</button>
    </div>
    <form action="/seafarers/update" method="POST">
      <input type="hidden" name="seafarer_id" id="edit_id">
      <div class="form-grid">
        <div class="form-group"><label>Full Name</label><input name="full_name" id="edit_name" required></div>
        <div class="form-group"><label>Nationality</label><input name="nationality" id="edit_nat" required></div>
        <div class="form-group"><label>Email</label><input name="email" id="edit_email"></div>
        <div class="form-group"><label>Phone (10 digits)</label><input name="phone" id="edit_phone" pattern="[0-9]{10}" maxlength="10" title="Enter exactly 10 digits"></div>
        <div class="form-group">
          <label>Rank</label>
          <select name="rank_id" id="edit_rank">
            <% ranks.forEach(r => { %><option value="<%= r.rank_id %>"><%= r.rank_name %></option><% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select name="status" id="edit_status">
            <option value="Active">Active</option>
            <option value="On Leave">On Leave</option>
            <option value="Retired">Retired</option>
          </select>
        </div>
      </div>
      <div class="form-actions" style="margin-top:16px">
        <button type="submit" class="btn btn-primary">💾 Save Changes</button>
        <button type="button" class="btn btn-outline" onclick="closeModal('editModal')">Cancel</button>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
